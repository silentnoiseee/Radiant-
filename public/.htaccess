# Radiant — static hosting rules for Hostinger/Apache/LiteSpeed

# 1) Never cache HTML, so a new deploy shows up immediately.
<FilesMatch "\.html$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </IfModule>
</FilesMatch>

# 2) Build assets have content-hashed names, so they can be cached forever.
<FilesMatch "\.(js|css|woff2|woff|ttf|otf|svg|png|jpe?g|gif|ico|webp|avif)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=31536000, immutable"
  </IfModule>
</FilesMatch>

# 3) Stop LiteSpeed (Hostinger's server cache) from serving stale HTML pages.
<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>
